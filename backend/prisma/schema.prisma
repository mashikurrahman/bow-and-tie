// ---------------------------------------------------------------------------
// Prisma schema for the Bow Clips & Hair Accessories store.
//
// The store runs on PostgreSQL everywhere (local, staging, production). Set
// DATABASE_URL in backend/.env to your connection string, e.g. a free Neon DB:
//   postgresql://user:password@ep-xxx.neon.tech/bowandtie?sslmode=require
// or the local docker-compose Postgres:
//   postgresql://postgres:postgres@localhost:5432/bowandtie?schema=public
//
// Then sync the schema and seed:  npm run deploy:db
// (`prisma db push` + seed). See DEPLOY.md for the full staging guide.
// ---------------------------------------------------------------------------

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  role          String    @default("customer") // "customer" | "admin" | "staff"
  permissions   String    @default("[]") // JSON array of section keys a staff user may access
  emailVerified Boolean   @default(false) // customer confirmed their email via the link
  adminNote     String    @default("") // private CRM note the shop keeps on this customer
  addresses     Address[]
  orders        Order[]
  createdAt     DateTime  @default(now())
}

model Address {
  id      String  @id @default(cuid())
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  label   String?
  name    String
  phone   String
  address String
  city    String
}

model Product {
  id            String   @id // slug, e.g. "satin-cloud-bow"
  name          String
  category      String
  price         Int // whole BDT
  originalPrice Int
  costPrice     Int      @default(0) // buying cost, used for profit reports (admin)
  stock         Int      @default(0)
  rating        Float    @default(0)
  reviewsCount  Int      @default(0)
  badge         String   @default("")
  description   String
  fabric        String   @default("")
  delivery      String   @default("")
  colors        String   @default("[]") // JSON array
  sizes         String   @default("[]") // JSON array
  gallery       String   @default("[]") // JSON array
  image         String
  inStock       Boolean  @default(true)
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  reviews       Review[]
  variants      ProductVariant[]
}

// An individual purchasable SKU of a product (e.g. "Blush / Small"), with its
// own price, stock and optional image. Optional: a product with no variants
// falls back to the product's own price & stock.
model ProductVariant {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  label     String // display name, e.g. "Blush / Small"
  color     String?
  size      String?
  price     Int // whole BDT
  stock     Int      @default(0)
  image     String? // optional variant-specific photo
  sku       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  userId    String? // links the review to the account that wrote it
  name      String
  rating    Int
  title     String   @default("")
  date      String
  text      String
  images    String   @default("[]") // JSON array of photo URLs
  verified  Boolean  @default(false) // true when the reviewer bought the product
  hidden    Boolean  @default(false) // moderated out of public view (spam/abuse)
  createdAt DateTime @default(now())
}

// A customer question on a product, optionally answered by the shop.
model Question {
  id         String    @id @default(cuid())
  productId  String
  userId     String?
  name       String
  question   String
  answer     String?
  answeredAt DateTime?
  createdAt  DateTime  @default(now())
}

// Newsletter signups from the storefront footer.
model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// A cart a shopper left without checking out — used to send a gentle reminder.
model AbandonedCart {
  id        String   @id @default(cuid())
  email     String   @unique
  items     String   @default("[]") // JSON snapshot [{ name, quantity, price, image }]
  total     Int      @default(0)
  reminded  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Someone who wants to be told when a sold-out product is restocked.
model StockAlert {
  id        String   @id @default(cuid())
  productId String
  email     String
  userId    String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([productId, email])
}

model Order {
  id              String      @id // custom, e.g. "BC1A2B3"
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?
  items           OrderItem[]
  subtotal        Int
  discount        Int         @default(0)
  shipping        Int         @default(0)
  total           Int
  customerName    String
  customerEmail   String? // used to send order confirmation / status emails
  customerPhone   String
  customerAddress String
  customerCity    String
  deliveryZone    String   @default("outside") // "inside" | "outside" (Dhaka)
  payment         String // "cod" | "bkash" | "nagad"
  txnId           String? // customer-entered bKash/Nagad transaction id
  paymentVerified Boolean @default(false) // admin confirmed the txn against their statement
  giftWrap        Boolean @default(false) // customer asked for gift wrapping
  giftMessage     String? // optional gift note to include with the order
  notes           String?
  promoCode       String?
  courier         String? // "pathao" | "steadfast" | "redx"
  trackingCode    String?
  status          String      @default("Processing")
  timeline        String      @default("[]") // JSON array of { status, at }
  // Return / refund tracking. refundStatus: null | "Requested" | "Approved" |
  // "Rejected" | "Refunded". Set when a customer requests a return and updated
  // by admin as the refund is processed.
  returnReason    String?
  refundStatus    String?
  refundAmount    Int?
  refundMethod    String? // "bkash" | "nagad" | "cash" | "original"
  refundedAt      DateTime?
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  productId String?
  variantId String? // the purchased SKU, when the product has variants
  name      String
  image     String
  price     Int
  quantity  Int
  color     String?
  size      String?
}

// A curated product set ("Complete the look" / "Shop the bundle"). The store
// shows the grouped products with an "add all to cart" action.
model Bundle {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  productIds  String   @default("[]") // JSON array of product ids, in display order
  image       String   @default("")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// A business expense, for the profit/P&L view (rent, materials, ads, etc.).
model Expense {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  category  String
  amount    Int // whole BDT
  note      String   @default("")
  createdAt DateTime @default(now())

  @@index([date])
}

// An audit trail of admin/staff mutations (who did what, when).
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // e.g. "PATCH /orders/BC123/status"
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// A saved, reusable email campaign (subject + HTML/text body) the admin can
// broadcast to newsletter subscribers.
model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Simple key/value store for editable storefront settings (e.g. the bKash /
// Nagad merchant numbers shown at checkout), so they can be changed from the
// admin panel without a code change or redeploy.
model Setting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

model Promo {
  code      String   @id
  rate      Float // 0.25 = 25% off
  active    Boolean  @default(true)
  label     String   @default("")
  createdAt DateTime @default(now())
}

// A promotion / campaign: auto-applies a % discount to all or selected
// products for an optional date window, and can surface as a home popup and a
// hero slider banner.
model Promotion {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  percent     Int // 25 = 25% off
  scope       String    @default("all") // "all" | "selected"
  productIds  String    @default("[]") // JSON array (when scope = selected)
  startsAt    DateTime?
  endsAt      DateTime?
  active      Boolean   @default(true)
  showPopup   Boolean   @default(true)
  showSlider  Boolean   @default(true)
  bgColor     String    @default("#c9527a")
  ctaLabel    String    @default("Shop the sale")
  createdAt   DateTime  @default(now())
}
