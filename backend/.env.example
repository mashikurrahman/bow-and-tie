# Copy to .env and fill in. The store runs on PostgreSQL everywhere.
# See DEPLOY.md for the full free staging setup (Neon + Render + Vercel).

# --- Database (PostgreSQL) ---
# A free Neon database (recommended — always-available, doesn't expire):
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/bowandtie?sslmode=require"
# ...or the local docker-compose Postgres (see docker-compose.yml):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bowandtie?schema=public"

JWT_SECRET="use-a-long-random-secret"
JWT_EXPIRES_IN="7d"
PORT=4000

# Set to "production" when deploying: enables trust-proxy for correct client IPs
# (rate limiting) and locks CORS to the origins below (no localhost fallback).
NODE_ENV="development"

# Browser origin(s) allowed to call the API. Comma-separate for multiple, e.g.
# "https://bowandtie.com,https://www.bowandtie.com". In dev any localhost port
# is also allowed automatically. On staging this is your Vercel URL.
CORS_ORIGIN="http://localhost:5173"

# Public storefront URL — used to build links inside emails (reset, orders…).
# On staging this is your Vercel URL.
APP_URL="http://localhost:5173"

# Absolute base URL of THIS API — used to build public image/upload links.
# On staging this is your Render backend URL, e.g. https://bow-and-tie-api.onrender.com
PUBLIC_URL="http://localhost:4000"
STORE_NAME="Bow & Tie"

# --- Admin account (seeded) ---
# On a PUBLIC server you MUST set these so the admin panel is not protected by
# the well-known demo login (admin@bowclips.com / admin123). When ADMIN_PASSWORD
# is set, the seed (re)applies it on every run and skips the demo customer.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# --- Transactional email ---
# RECOMMENDED (esp. on Render, which blocks outbound SMTP ports): Brevo's HTTP
# API. Get an API key at Brevo → SMTP & API → API keys (starts with "xkeysib-").
# This sends over HTTPS so it isn't affected by blocked SMTP ports.
BREVO_API_KEY=""
EMAIL_FROM="Bow & Tie <no-reply@bowandtie.com>"

# SMTP fallback (used only if BREVO_API_KEY is empty). Works locally / on hosts
# that permit outbound SMTP. If neither is set, emails log to the console.
#   Brevo:  SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
#   Resend: SMTP_HOST=smtp.resend.com       SMTP_PORT=587  SMTP_USER=resend
#   Gmail:  SMTP_HOST=smtp.gmail.com        SMTP_PORT=587  (use an App Password)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# --- WhatsApp admin alerts (optional, Meta Cloud API) ---
# Leave empty in dev: alerts (new order, low stock, restock, weekly/monthly
# reports) are logged to the console. To actually send, create a Meta WhatsApp
# Business app, then set the access token, the sender phone-number ID, and the
# admin's WhatsApp number (international format, no +).
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_ADMIN_TO="8801XXXXXXXXX"
LOW_STOCK_THRESHOLD=5

# --- Courier integration (optional) ---
# Empty → shipping generates a mock tracking code so the flow works in dev.
# Add a merchant account's credentials to book real consignments.
STEADFAST_API_KEY=""
STEADFAST_SECRET=""
PATHAO_CLIENT_ID=""
PATHAO_CLIENT_SECRET=""
REDX_API_TOKEN=""

# --- Image storage (Cloudflare R2 / S3-compatible) ---
# WHERE UPLOADED PRODUCT IMAGES ARE STORED. Leave empty in dev → images are
# saved to the local ./uploads folder. On an ephemeral host (Render's free disk
# is wiped on every redeploy) you MUST set these, or uploaded images disappear.
# Cloudflare R2 is free for this scale (10 GB storage, no egress fees).
# Create a bucket + an R2 API token (Object Read & Write), enable public access
# (r2.dev URL or a custom domain), then fill in:
R2_ACCOUNT_ID=""          # Cloudflare account id (from the R2 dashboard)
R2_ACCESS_KEY_ID=""       # R2 API token access key id
R2_SECRET_ACCESS_KEY=""   # R2 API token secret access key
R2_BUCKET=""              # bucket name, e.g. bowandtie-uploads
R2_PUBLIC_URL=""          # public base URL, e.g. https://pub-xxxx.r2.dev (no trailing slash)
# For AWS S3 or another provider instead of R2: leave R2_ACCOUNT_ID empty and
# set R2_ENDPOINT to the full S3 endpoint (e.g. https://s3.ap-south-1.amazonaws.com).
R2_ENDPOINT=""

# --- Social login (optional) ---
# Create OAuth apps (Google Cloud Console / Meta for Developers) and set the IDs.
# The same Google client ID must also be set in the frontend as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
